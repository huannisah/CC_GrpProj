# === CareerAI-as-a-Service Environment Variables ===
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# Session secret key (change to a random string in production)
SECRET_KEY=change-me-to-a-random-string

# OpenAI API key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-5.4-nano

# Databricks connection — get from your Databricks workspace
# (SQL Warehouses → Connection Details tab)
DATABRICKS_HOST=https://adb-xxxxxxxxxxxxxxxx.azuredatabricks.net
DATABRICKS_TOKEN=dapixxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=careerai
